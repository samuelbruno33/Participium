DATABASE_URL=sqlite+pysqlite:///instance/participium.db
SECRET_KEY=participium-dev-secret
FLASK_ENV=development
HOST=0.0.0.0
PORT=5050
FRONTEND_ORIGIN=http://localhost:5173
AUTO_INIT_DB=true
BOOTSTRAP_REFERENCE_DATA=true
BOOTSTRAP_DEMO_DATA=true
MAIL_BACKEND=console
MAIL_FROM=noreply@participium.local
MAIL_OUTBOX_DIR=instance/outbox
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EXPOSE_VERIFICATION_LINKS=true
MEDIA_ROOT=participium/static/uploads
MAX_CONTENT_LENGTH=16777216
